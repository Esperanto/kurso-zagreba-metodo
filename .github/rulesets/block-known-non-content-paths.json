{
  "name": "Bloku konatajn neenhavajn vojojn",
  "target": "push",
  "enforcement": "active",
  "bypass_actors": [],
  "rules": [
    {
      "type": "file_path_restriction",
      "parameters": {
        "restricted_file_paths": [
          "*",
          ".gitignore",
          ".gitmodules",
          ".github/*",
          ".github/**/*",
          ".idea/*",
          ".idea/**/*",
          "__pycache__/*",
          "__pycache__/**/*",
          "agordoj/*",
          "agordoj/**/*",
          "bildoj/*",
          "bildoj/**/*",
          "genanki/*",
          "genanki/**/*",
          "html_generiloj/*",
          "html_generiloj/**/*",
          "leo_markdown/*",
          "leo_markdown/**/*",
          "maintenance/*",
          "maintenance/**/*",
          "pad/*",
          "pad/**/*",
          "projects/*",
          "projects/**/*",
          "venv/*",
          "venv/**/*",
          ".venv/*",
          ".venv/**/*"
        ]
      }
    }
  ]
}
